NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_assistant?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_DAYS=7
PUBLIC_URL=http://localhost:3000

# Development: no SMTP — verification links log to the server console.
# Auto-verify on register/login (default true when NODE_ENV=development).
# Set to false to test the real verify-email flow locally.
AUTH_DEV_AUTO_VERIFY_EMAIL=true

# Optional OAuth (required for Google/Apple sign-in)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Listing sync → Postgres properties → RAG embeddings (M4/M6)
# Guest API: GET https://shaety.pountech.com/api/properties (no key required).
# Optional SHAETY_API_KEY for authenticated Sanctum token (higher limits).
# Falls back to mock-listings.json only if live API is unreachable.
SHAETY_API_URL=https://shaety.pountech.com
SHAETY_API_KEY=
SHAETY_PLATFORM=android
SHAETY_APP_VERSION=1.0.0
